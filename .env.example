# ═══════════════════════════════════════════════════════════
# Shiphny AI Support Agent — Environment Configuration
# Copy this file to backend/.env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────
APP_NAME="SupportBot Pro"
APP_VERSION="2.0.0"
DEBUG=false

# ── Database ─────────────────────────────────────────────
# SQLite for local dev (auto-created on first run):
DATABASE_URL=sqlite+aiosqlite:///./supportbot.db
# PostgreSQL for production:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/supportbot

# ── AI Providers (Smart Chain: OpenRouter → Groq → Gemini → Static) ──
# At least ONE key is recommended. The system auto-switches between providers.
# If ALL keys are missing or rate-limited, a context-aware static fallback is used.

# Provider 1 — OpenRouter (free models, recommended)
# Sign up: https://openrouter.ai → Dashboard → API Keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Provider 2 — Groq (ultra-fast inference)
# Sign up: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_your-key-here
GROQ_MODEL=llama-3.1-8b-instant

# Provider 3 — Google Gemini (generous free tier)
# Sign up: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# ── Security ──────────────────────────────────────────────
SECRET_KEY=change-me-to-a-strong-random-secret

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
